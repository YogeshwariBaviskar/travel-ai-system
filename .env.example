# LLM
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google OAuth (login + calendar)
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret_here

# External APIs
AMADEUS_API_KEY=your_amadeus_api_key_here
AMADEUS_API_SECRET=your_amadeus_api_secret_here
BOOKING_API_KEY=your_booking_rapidapi_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Notifications
FCM_SERVER_KEY=your_fcm_server_key_here
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1234567890

# Webhook security
WEBHOOK_SECRET=your_random_webhook_secret_here

# Database
DATABASE_URL=postgresql://travel_ai:travel_ai_pass@localhost:5432/travel_ai

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET_KEY=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# App URLs
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Vector DB (prod)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENV=us-east-1

# FAISS index path (dev)
FAISS_INDEX_PATH=/tmp/travel_ai_faiss
